{
 "Version": "2012-10-17",
    "Statement":  [
    {
      "Effect": "Allow",
      "Action": ["var.dynamodb_actions"],
      "Resource" : "var.dynamodb_arn"
    },
    {
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogGroup",
        "logs:CreateLogStream",
        "logs:PutLogEvents"
      ],
      "Resource": "*"
    }
    ]
  }